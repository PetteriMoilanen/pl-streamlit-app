{
  "name": "Football App Dev Env",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  "features": {
    "ghcr.io/jsburckhardt/devcontainer-features/uv:1": {},
    "ghcr.io/jsburckhardt/devcontainer-features/ruff:1": {}
  },

  "customizations": {
    "vscode": {
      "settings": {
        // Absolute container workspace path
        "python.defaultInterpreterPath": "/workspaces/pl-streamlit-app/.venv/bin/python",
        "python.testing.pytestEnabled": true
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml"
      ]
    }
  },

  // Runs once when the container is first created
  "postCreateCommand": "uv sync",
  
  // Runs every time the Codespace starts up to refresh packages
  "postStartCommand": "uv sync",

  "remoteUser": "vscode"
}